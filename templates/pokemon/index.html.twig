{% extends 'base.html.twig' %}

{% block title %}Pokemon index{% endblock %}

{% block body %}
<h1 class=" mt-6 flex flex-row justify-center  mb-4 text-4xl font-bold tracking-tight text-heading md:text-5xl lg:text-6xl">We invest in the Pokemon’s potential</h1>

<div class="container mx-auto p-4">

    <div class="flex justify-between items-center mb-8">
        <div class="text-4xl font-bold">Nombres de pokémon : {{ pokemon|length }}</div>
        <a  href="{{ path('app_pokemon_new') }}"
            class=" p-8 py-4 text-white text-2xl font-semibold bg-[#3dc361]    hover:bg-[#ff8904] focus:ring-4 focus:ring-[#ff8904]  rounded-xl transition-colors duration-200">
            Ajouter</a>
    </div>
    <table class="table w-full">
        <tbody>
            {% for pokemon in pokemon %}
            <tr class="flex flex-row items-center justify-between bg-[#1E1E1E] text-white text-2xl px-4 py-2 gap-4 my-8 ">
                <td class="w-8">{{ pokemon.id }}</td>
                <td class="flex-1 text-4xl">{{ pokemon.name }}</td>
                <td > <img class="object-cover w-36"src="{{ pokemon.imageUrl }}" alt="{{ pokemon.name }}"> </td>
                <td class="flex gap-2">
                    <a class="bg-[#ff8904]    hover:bg-[#3dc361] focus:ring-4 focus:ring-[#3dc361]  rounded" href="{{ path('app_pokemon_show', {'id': pokemon.id}) }}">show</a>
                    <a class="bg-[#3dc361]    hover:bg-[#ff8904] focus:ring-4 focus:ring-[#ff8904]  rounded" href="{{ path('app_pokemon_edit', {'id': pokemon.id}) }}">edit</a>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>



    {% endblock %}