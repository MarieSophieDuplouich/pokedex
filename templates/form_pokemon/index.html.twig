{% extends 'base.html.twig' %}

{% block title %}Hello FormPokemonController!{% endblock %}

{% block body %}
<div class="">

        <div class="container mx-auto p-4">

                <div class="flex justify-between items-center mb-4">
                        <div class="text-4xl">Nombres de pokémon : 20</div>
                        <button type="button"
                                class=" p-8 text-white text-4xl bg-[#3dc361]    hover:bg-[#ff8904] focus:ring-4 focus:ring-[#ff8904]  rounded">
                                Accueil</button>
                </div>

                <!-- //TODO: Formulaire d'ajout de pokémon MSD -->
 <form class="flex flex-col justify-center" action="" method="post" enctype="multipart/form-data"
        class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 shadow-xl max-w-2xl">

        <!-- Nom du Pokémon -->
        <div class="mb-6">
            <input
                id="name"
                type="text"
                name="name"
                placeholder="Nom du Pokémon"
                class="w-full px-4 py-3 rounded-xl bg-white/30  text-lg placeholder:text-white border-2 border-transparent focus:border-[#3dc361] focus:outline-none transition-colors duration-200"
            />
        </div>

        <!-- Image du Pokémon -->
        <div class="mb-8">
            <label class="block text-white text-xl font-semibold mb-2">
                Image du Pokémon
            </label>
            <label for="file-upload"
                class="flex flex-col items-center justify-center w-full h-48 rounded-xl border-2 border-dashed border-white/50 bg-white/10 hover:bg-white/20 cursor-pointer transition-colors duration-200 group">
                <svg class="w-12 h-12 text-white/60 group-hover:text-white mb-3 transition-colors duration-200" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M1.5 6a2.25 2.25 0 0 1 2.25-2.25h16.5A2.25 2.25 0 0 1 22.5 6v12a2.25 2.25 0 0 1-2.25 2.25H3.75A2.25 2.25 0 0 1 1.5 18V6ZM3 16.06V18c0 .414.336.75.75.75h16.5A.75.75 0 0 0 21 18v-1.94l-2.69-2.689a1.5 1.5 0 0 0-2.12 0l-.88.879.97.97a.75.75 0 1 1-1.06 1.06l-5.16-5.159a1.5 1.5 0 0 0-2.12 0L3 16.061Zm10.125-7.81a1.125 1.125 0 1 1 2.25 0 1.125 1.125 0 0 1-2.25 0Z" clip-rule="evenodd" fill-rule="evenodd"/>
                </svg>
                <span class="text-white/70 group-hover:text-white text-sm transition-colors duration-200">Parcourir ou glisser une image ici</span>
                <span class="text-white/40 text-xs mt-1">PNG, JPG, GIF — max 10MB</span>
                <input id="file-upload" type="file" name="file-upload" class="sr-only" accept="image/*"/>
            </label>
        </div>

        <!-- Boutons -->
        <div class="flex items-center justify-end gap-4">
            <button type="button"
                class="px-6 py-3 text-white/80 text-lg font-semibold hover:text-white transition-colors duration-200">
                Annuler
            </button>
            <button type="submit"
                class="px-10 py-4 text-white text-xl font-semibold bg-[#3dc361] hover:bg-[#ff8904] focus:ring-4 focus:ring-[#ff8904] rounded-xl transition-colors duration-200">
                Ajouter
            </button>
        </div>

    </form>

</div>
{% endblock %}